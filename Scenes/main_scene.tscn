[sub_resource type="GDScript" id="GDScript_5oxhp"]
resource_name = "DracaufeuMain"
script/source = "extends Node2D
@export var animatedSprite:AnimatedSprite2D
@export var timerShoot:Timer
@export var shouldShoot=false
@export var flame:PackedScene
@export var blasting:bool=false
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if blasting:
		animatedSprite.play(\"shootingLong\")
	else :
		if shouldShoot and timerShoot.is_stopped():
			animatedSprite.play(\"shooting\")
			timerShoot.start()
			var newFlame = flame.instantiate()
			newFlame.global_position=$Sprite/FlameOrigin.global_position
			get_tree().root.add_child(newFlame)
			$ShootSound.play()
		if animatedSprite.animation==\"shooting\" and animatedSprite.frame==7:
			animatedSprite.play(\"idle\")
	pass
"

